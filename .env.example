# Required — App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# Required — Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/ai_for_nurses_india

# Required — Auth
AUTH_SECRET=replace_with_long_random_secret_min_32_chars
AUTH_URL=http://localhost:3000

# Optional — Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required (at least one) — AI Providers
GEMINI_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER_DEFAULT=gemini
AI_GLOBAL_SHUTDOWN=false

# Optional — Redis (for rate limiting, token counters)
REDIS_URL=

# Optional — Object Storage (Cloudflare R2 / S3-compatible)
STORAGE_PROVIDER=r2
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# Optional — Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_test_SSg2uz4zfyBYkn
RAZORPAY_KEY_SECRET=6AyAarSM4plW0KgXBM3MttVA
RAZORPAY_WEBHOOK_SECRET=

# Optional — Email (Resend)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
